{
  "name": "@dtcg-formulas/parser",
  "version": "0.1.0",
  "description": "Parser for .module.scssdef definition files used by dtcg-formulas.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/beacrea/dtcg-formulas.git",
    "directory": "packages/parser"
  },
  "bugs": {
    "url": "https://github.com/beacrea/dtcg-formulas/issues"
  },
  "homepage": "https://dtcg-formulas.org",
  "keywords": ["dtcg", "design-tokens", "formulas", "sass", "scssdef", "parser"]
}
